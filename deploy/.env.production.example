# Production environment — copy to /var/www/altons-carwash/.env on the VM
# Replace YOUR_DOMAIN_OR_IP with your real URL (no trailing slash)

NODE_ENV=production
PORT=3000

DATABASE_URL="file:/var/www/altons-carwash/prisma/dev.db"

# MUST match how you open the site in the browser (http until Certbot, then https).
# Wrong scheme = login breaks or redirects to unreachable https://
NEXTAUTH_URL="http://YOUR_EXTERNAL_IP"
NEXTAUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# Optional SMTP fallback (can also configure in Admin UI)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Optional: override default admin on first seed only
# ADMIN_EMAIL="admin@altonscarwash.com"
# ADMIN_PASSWORD="use-a-strong-password"
