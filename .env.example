# Copy to .env and fill in values
DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret-here"

# Optional Gmail SMTP fallback (configure in Admin → Settings instead if you prefer)
# Requires 2-Step Verification + App Password: https://myaccount.google.com/apppasswords
# Use the 16-char app password (not your normal Gmail password). Spaces are OK.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="you@gmail.com"
